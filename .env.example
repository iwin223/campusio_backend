# Environment Configuration Example
# Copy this file to .env and fill in your actual values

# ========================
# Database Configuration
# ========================
DATABASE_URL=postgresql+asyncpg://user:password@localhost/school_erp_db

# ========================
# JWT Configuration
# ========================
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ========================
# SMTP Configuration (Email OTP)
# ========================
# Gmail SMTP Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# To get Gmail app password:
# 1. Enable 2-Step Verification: https://myaccount.google.com
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password here

# ========================
# USMS-GH SMS Configuration (OTP Delivery)
# ========================
# Get these from https://www.usmsgh.com
USMSGH_API_TOKEN=your-api-token-here
USMSGH_SENDER_ID=SchoolERP

# To get USMS-GH credentials:
# 1. Create account at https://www.usmsgh.com
# 2. Go to Settings/API Keys to get API_TOKEN
# 3. Register Sender ID (max 11 characters)
# 4. Add credits to account
# 5. Test with test phone number first

# ========================
# AWS Configuration (Optional - for file storage)
# ========================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_REGION=us-east-1

# ========================
# Logging Configuration
# ========================
LOG_LEVEL=INFO
# DEBUG for development, INFO for production

# ========================
# Server Configuration
# ========================
HOST=0.0.0.0
PORT=8000
DEBUG=True

# ========================
# Frontend Configuration
# ========================
REACT_APP_API_BASE_URL=http://localhost:8000

# ========================
# Security Configuration
# ========================
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# ========================
# Optional: Rate Limiting
# ========================
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# ========================
# Optional: Monitoring
# ========================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_SAMPLE_RATE=0.1

# ========================
# Optional: Third-party Services
# ========================
# Stripe (for payment processing)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# Sendgrid (alternative email provider)
SENDGRID_API_KEY=

# Firebase (optional)
FIREBASE_CONFIG=
